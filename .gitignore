# ======================================================
# .gitignore — Claim Denial Prevention System
# ======================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# --- Virtual Environment ---
venv/
env/
.venv/

# --- Secrets & Environment Variables ---
.env
*.env

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- IDE ---
.vscode/settings.json
.idea/
*.swp
*.swo

# --- Test cache ---
.pytest_cache/
.coverage
htmlcov/

# --- Logs ---
logs/*.log

# --- Databricks (not needed locally) ---
.databricks/

# --- Jupyter Notebooks checkpoints ---
.ipynb_checkpoints/

# --- Data: RAW source files (large, regenerated by ingestion pipeline) ---
# NOTE: Bronze/Silver/Gold CSVs ARE committed so the app runs on a fresh clone
#       without re-running the pipeline. Only raw source data is excluded.
data/raw/*.csv

# --- Large binary model files (keep small ones, .pkl is ~240KB so we keep it) ---
# Uncomment below ONLY if models exceed 100MB GitHub limit:
# models/*.pkl
