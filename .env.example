# ============================================================
# .env.example — Copy to .env and fill in your values
# cp .env.example .env
# ============================================================

# JWT secret key — change this to a long random string in production
JWT_SECRET_KEY=claimops-change-this-to-a-long-random-secret

# Database URL — leave as SQLite for local/demo, swap for PostgreSQL in cloud
# SQLite (default):
DATABASE_URL=sqlite:///./claimops.db
# PostgreSQL (production on AWS RDS / Render):
# DATABASE_URL=postgresql://user:password@host:5432/claimops

# App environment
APP_ENV=development

# AWS credentials (only needed if using S3 for model storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
